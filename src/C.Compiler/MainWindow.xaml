<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="C.Compiler.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:C.Compiler"
    xmlns:controls="using:C.Compiler.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Turbo C">

    <Grid x:Name="RootGrid" Background="#FF0000AA">
        <Grid.RowDefinitions>
            <RowDefinition Height="24"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2"/>
            <RowDefinition Height="140"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- ROW 0: CUSTOM MENU BAR (no WinUI MenuBar)      -->
        <!-- Gray background, black text, flat buttons       -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid Grid.Row="0" x:Name="MenuBarGrid" Background="#FFAAAAAA">
            <StackPanel x:Name="MenuBarPanel" Orientation="Horizontal" VerticalAlignment="Stretch">
                <Button x:Name="SysMenuBtn"     Content=" ≡ "       Style="{StaticResource DosMenuTitleStyle}" Click="MenuTitle_Click" PointerEntered="MenuTitle_Hover" Tag="0"/>
                <Button x:Name="FileMenuBtn"    Content=" File "    Style="{StaticResource DosMenuTitleStyle}" Click="MenuTitle_Click" PointerEntered="MenuTitle_Hover" Tag="1"/>
                <Button x:Name="EditMenuBtn"    Content=" Edit "    Style="{StaticResource DosMenuTitleStyle}" Click="MenuTitle_Click" PointerEntered="MenuTitle_Hover" Tag="2"/>
                <Button x:Name="SearchMenuBtn"  Content=" Search "  Style="{StaticResource DosMenuTitleStyle}" Click="MenuTitle_Click" PointerEntered="MenuTitle_Hover" Tag="3"/>
                <Button x:Name="RunMenuBtn"     Content=" Run "     Style="{StaticResource DosMenuTitleStyle}" Click="MenuTitle_Click" PointerEntered="MenuTitle_Hover" Tag="4"/>
                <Button x:Name="CompileMenuBtn" Content=" Compile " Style="{StaticResource DosMenuTitleStyle}" Click="MenuTitle_Click" PointerEntered="MenuTitle_Hover" Tag="5"/>
                <Button x:Name="DebugMenuBtn"   Content=" Debug "   Style="{StaticResource DosMenuTitleStyle}" Click="MenuTitle_Click" PointerEntered="MenuTitle_Hover" Tag="6"/>
                <Button x:Name="ProjectMenuBtn" Content=" Project " Style="{StaticResource DosMenuTitleStyle}" Click="MenuTitle_Click" PointerEntered="MenuTitle_Hover" Tag="7"/>
                <Button x:Name="OptionsMenuBtn" Content=" Options " Style="{StaticResource DosMenuTitleStyle}" Click="MenuTitle_Click" PointerEntered="MenuTitle_Hover" Tag="8"/>
                <Button x:Name="WindowMenuBtn"  Content=" Window "  Style="{StaticResource DosMenuTitleStyle}" Click="MenuTitle_Click" PointerEntered="MenuTitle_Hover" Tag="9"/>
                <Button x:Name="HelpMenuBtn"    Content=" Help "    Style="{StaticResource DosMenuTitleStyle}" Click="MenuTitle_Click" PointerEntered="MenuTitle_Hover" Tag="10"/>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- ROW 1: EDITOR AREA                              -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="2">
            <controls:EditorControl x:Name="ActiveEditor"/>
        </Grid>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- ROW 2: DIVIDER                                  -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#FF00AAAA"/>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- ROW 3: MESSAGE WINDOW                           -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border Grid.Row="3" x:Name="MessagePanel"
                BorderBrush="#FF00AAAA" BorderThickness="2"
                Margin="2,0,2,0" Background="#FF000088" CornerRadius="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="22"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Background="#FF00AAAA">
                    <TextBlock Text="═══════════════════ Message ═══════════════════"
                               FontFamily="Consolas" FontSize="12"
                               Foreground="#FF000000" HorizontalAlignment="Center"
                               VerticalAlignment="Center" FontWeight="Bold"/>
                </Grid>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="Transparent">
                    <ItemsControl x:Name="MessageList" Padding="4,2">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           FontFamily="Consolas" FontSize="13"
                                           Foreground="#FFFFFFFF" TextWrapping="NoWrap" Padding="0,1"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- ROW 4: STATUS BAR                               -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid Grid.Row="4" Background="#FF00AAAA" Padding="2,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" FontFamily="Consolas" FontSize="12"
                       Foreground="#FF000000" VerticalAlignment="Center">
                <Run Text=" F1" FontWeight="Bold" Foreground="#FFFFFFFF"/><Run Text=" Help "/>
                <Run Text="│"/>
                <Run Text=" F2" FontWeight="Bold" Foreground="#FFFFFFFF"/><Run Text=" Save "/>
                <Run Text="│"/>
                <Run Text=" F3" FontWeight="Bold" Foreground="#FFFFFFFF"/><Run Text=" Open "/>
                <Run Text="│"/>
                <Run Text=" Alt+F9" FontWeight="Bold" Foreground="#FFFFFFFF"/><Run Text=" Compile "/>
                <Run Text="│"/>
                <Run Text=" F9" FontWeight="Bold" Foreground="#FFFFFFFF"/><Run Text=" Make "/>
                <Run Text="│"/>
                <Run Text=" F10" FontWeight="Bold" Foreground="#FFFFFFFF"/><Run Text=" Menu"/>
            </TextBlock>
            <TextBlock Grid.Column="1" x:Name="StatusLineCol" Text="1:1"
                       FontFamily="Consolas" FontSize="12"
                       Foreground="#FF000000" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="8,0"/>
        </Grid>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- MENU DROPDOWN POPUPS                            -->
        <!-- Each Popup is positioned absolutely via code    -->
        <!-- ═══════════════════════════════════════════════ -->

        <!-- ≡ System Menu -->
        <Popup x:Name="MenuPopup0" IsLightDismissEnabled="True" Closed="MenuPopup_Closed">
            <Grid>
                <Border Margin="2,2,0,0" Background="#FF000055" CornerRadius="0"/>
                <Border Background="#FFAAAAAA" BorderBrush="#FF555555" BorderThickness="1" Margin="0,0,2,2" CornerRadius="0">
                    <StackPanel MinWidth="180">
                        <Button Content=" About...               " Style="{StaticResource DosMenuItemStyle}" Click="About_Click"/>
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button Content=" Clear Desktop           " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Repaint Desktop         " Style="{StaticResource DosMenuItemStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <!-- File Menu -->
        <Popup x:Name="MenuPopup1" IsLightDismissEnabled="True" Closed="MenuPopup_Closed">
            <Grid>
                <Border Margin="2,2,0,0" Background="#FF000055" CornerRadius="0"/>
                <Border Background="#FFAAAAAA" BorderBrush="#FF555555" BorderThickness="1" Margin="0,0,2,2" CornerRadius="0">
                    <StackPanel MinWidth="220">
                        <Button Content=" New                     " Style="{StaticResource DosMenuItemStyle}" Click="FileNew_Click"/>
                        <Button Content=" Open...            F3   " Style="{StaticResource DosMenuItemStyle}" Click="FileOpen_Click"/>
                        <Button Content=" Save              F2   " Style="{StaticResource DosMenuItemStyle}" Click="FileSave_Click"/>
                        <Button Content=" Save as...              " Style="{StaticResource DosMenuItemStyle}" Click="FileSaveAs_Click"/>
                        <Button Content=" Save all                " Style="{StaticResource DosMenuItemStyle}"/>
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button Content=" Change dir...           " Style="{StaticResource DosMenuItemStyle}" Click="ChangeDir_Click"/>
                        <Button Content=" Print                   " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" DOS shell               " Style="{StaticResource DosMenuItemStyle}" Click="DosShell_Click"/>
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button Content=" Quit            Alt+X  " Style="{StaticResource DosMenuItemStyle}" Click="Quit_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <!-- Edit Menu -->
        <Popup x:Name="MenuPopup2" IsLightDismissEnabled="True" Closed="MenuPopup_Closed">
            <Grid>
                <Border Margin="2,2,0,0" Background="#FF000055" CornerRadius="0"/>
                <Border Background="#FFAAAAAA" BorderBrush="#FF555555" BorderThickness="1" Margin="0,0,2,2" CornerRadius="0">
                    <StackPanel MinWidth="250">
                        <Button Content=" Undo          Ctrl+Z    " Style="{StaticResource DosMenuItemStyle}" Click="EditUndo_Click"/>
                        <Button Content=" Redo          Ctrl+Y    " Style="{StaticResource DosMenuItemStyle}" Click="EditRedo_Click"/>
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button Content=" Cut         Shift+Del   " Style="{StaticResource DosMenuItemStyle}" Click="EditCut_Click"/>
                        <Button Content=" Copy        Ctrl+Ins    " Style="{StaticResource DosMenuItemStyle}" Click="EditCopy_Click"/>
                        <Button Content=" Paste       Shift+Ins   " Style="{StaticResource DosMenuItemStyle}" Click="EditPaste_Click"/>
                        <Button Content=" Clear        Ctrl+Del   " Style="{StaticResource DosMenuItemStyle}"/>
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button Content=" Copy example            " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Show clipboard          " Style="{StaticResource DosMenuItemStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <!-- Search Menu -->
        <Popup x:Name="MenuPopup3" IsLightDismissEnabled="True" Closed="MenuPopup_Closed">
            <Grid>
                <Border Margin="2,2,0,0" Background="#FF000055" CornerRadius="0"/>
                <Border Background="#FFAAAAAA" BorderBrush="#FF555555" BorderThickness="1" Margin="0,0,2,2" CornerRadius="0">
                    <StackPanel MinWidth="260">
                        <Button Content=" Find...                  " Style="{StaticResource DosMenuItemStyle}" Click="SearchFind_Click"/>
                        <Button Content=" Replace...               " Style="{StaticResource DosMenuItemStyle}" Click="SearchReplace_Click"/>
                        <Button Content=" Search again             " Style="{StaticResource DosMenuItemStyle}" Click="SearchAgain_Click"/>
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button Content=" Go to line number...     " Style="{StaticResource DosMenuItemStyle}" Click="GoToLine_Click"/>
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button Content=" Find procedure...        " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Find error               " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Previous error    Alt+F7 " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Next error        Alt+F8 " Style="{StaticResource DosMenuItemStyle}" Click="NextError_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <!-- Run Menu -->
        <Popup x:Name="MenuPopup4" IsLightDismissEnabled="True" Closed="MenuPopup_Closed">
            <Grid>
                <Border Margin="2,2,0,0" Background="#FF000055" CornerRadius="0"/>
                <Border Background="#FFAAAAAA" BorderBrush="#FF555555" BorderThickness="1" Margin="0,0,2,2" CornerRadius="0">
                    <StackPanel MinWidth="250">
                        <Button Content=" Run            Ctrl+F9  " Style="{StaticResource DosMenuItemStyle}" Click="RunProgram_Click"/>
                        <Button Content=" Program reset  Ctrl+F2  " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Go to cursor      F4    " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Trace into        F7    " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Step over         F8    " Style="{StaticResource DosMenuItemStyle}"/>
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button Content=" Arguments...             " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" User screen    Alt+F5   " Style="{StaticResource DosMenuItemStyle}" Click="UserScreen_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <!-- Compile Menu -->
        <Popup x:Name="MenuPopup5" IsLightDismissEnabled="True" Closed="MenuPopup_Closed">
            <Grid>
                <Border Margin="2,2,0,0" Background="#FF000055" CornerRadius="0"/>
                <Border Background="#FFAAAAAA" BorderBrush="#FF555555" BorderThickness="1" Margin="0,0,2,2" CornerRadius="0">
                    <StackPanel MinWidth="260">
                        <Button Content=" Compile to OBJ  Alt+F9  " Style="{StaticResource DosMenuItemStyle}" Click="Compile_Click"/>
                        <Button Content=" Make EXE          F9    " Style="{StaticResource DosMenuItemStyle}" Click="Make_Click"/>
                        <Button Content=" Link EXE file           " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Build all               " Style="{StaticResource DosMenuItemStyle}"/>
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button Content=" Primary C file...       " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Get info                " Style="{StaticResource DosMenuItemStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <!-- Debug Menu -->
        <Popup x:Name="MenuPopup6" IsLightDismissEnabled="True" Closed="MenuPopup_Closed">
            <Grid>
                <Border Margin="2,2,0,0" Background="#FF000055" CornerRadius="0"/>
                <Border Background="#FFAAAAAA" BorderBrush="#FF555555" BorderThickness="1" Margin="0,0,2,2" CornerRadius="0">
                    <StackPanel MinWidth="260">
                        <Button Content=" Evaluate/modify Ctrl+F4 " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Watches                 " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Toggle breakpoint Ctrl+F8" Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Breakpoints...          " Style="{StaticResource DosMenuItemStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <!-- Project Menu -->
        <Popup x:Name="MenuPopup7" IsLightDismissEnabled="True" Closed="MenuPopup_Closed">
            <Grid>
                <Border Margin="2,2,0,0" Background="#FF000055" CornerRadius="0"/>
                <Border Background="#FFAAAAAA" BorderBrush="#FF555555" BorderThickness="1" Margin="0,0,2,2" CornerRadius="0">
                    <StackPanel MinWidth="220">
                        <Button Content=" Open project...         " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Close project           " Style="{StaticResource DosMenuItemStyle}"/>
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button Content=" Add item...             " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Delete item             " Style="{StaticResource DosMenuItemStyle}"/>
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button Content=" Local options...        " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Include files...        " Style="{StaticResource DosMenuItemStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <!-- Options Menu -->
        <Popup x:Name="MenuPopup8" IsLightDismissEnabled="True" Closed="MenuPopup_Closed">
            <Grid>
                <Border Margin="2,2,0,0" Background="#FF000055" CornerRadius="0"/>
                <Border Background="#FFAAAAAA" BorderBrush="#FF555555" BorderThickness="1" Margin="0,0,2,2" CornerRadius="0">
                    <StackPanel MinWidth="220">
                        <Button Content=" Compiler...             " Style="{StaticResource DosMenuItemStyle}" Click="OptionsCompiler_Click"/>
                        <Button Content=" Linker...               " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Make...                 " Style="{StaticResource DosMenuItemStyle}"/>
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button Content=" Directories...          " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Arguments...            " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Environment             " Style="{StaticResource DosMenuItemStyle}"/>
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button Content=" Save options...         " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Retrieve options...     " Style="{StaticResource DosMenuItemStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <!-- Window Menu -->
        <Popup x:Name="MenuPopup9" IsLightDismissEnabled="True" Closed="MenuPopup_Closed">
            <Grid>
                <Border Margin="2,2,0,0" Background="#FF000055" CornerRadius="0"/>
                <Border Background="#FFAAAAAA" BorderBrush="#FF555555" BorderThickness="1" Margin="0,0,2,2" CornerRadius="0">
                    <StackPanel MinWidth="260">
                        <Button Content=" Size/Move    Ctrl+F5    " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Zoom            F5      " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Tile                    " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Cascade                 " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Next              F6    " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Previous       Shift+F6 " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Close          Alt+F3   " Style="{StaticResource DosMenuItemStyle}"/>
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button Content=" List all...    Alt+0    " Style="{StaticResource DosMenuItemStyle}" Click="WindowList_Click"/>
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button Content=" Message                 " Style="{StaticResource DosMenuItemStyle}" Click="ToggleMessageWindow_Click"/>
                        <Button Content=" Output                  " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Watch                   " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" User screen    Alt+F5   " Style="{StaticResource DosMenuItemStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <!-- Help Menu -->
        <Popup x:Name="MenuPopup10" IsLightDismissEnabled="True" Closed="MenuPopup_Closed">
            <Grid>
                <Border Margin="2,2,0,0" Background="#FF000055" CornerRadius="0"/>
                <Border Background="#FFAAAAAA" BorderBrush="#FF555555" BorderThickness="1" Margin="0,0,2,2" CornerRadius="0">
                    <StackPanel MinWidth="250">
                        <Button Content=" Contents           F1   " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Index          Shift+F1 " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Topic search   Ctrl+F1  " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Previous topic Alt+F1   " Style="{StaticResource DosMenuItemStyle}"/>
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button Content=" Help on help            " Style="{StaticResource DosMenuItemStyle}"/>
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button Content=" About...                " Style="{StaticResource DosMenuItemStyle}" Click="About_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- DIALOG OVERLAYS — inline panels, no WinUI      -->
        <!-- ContentDialog. Pure DOS-styled.                 -->
        <!-- ═══════════════════════════════════════════════ -->

        <!-- FIND / REPLACE DIALOG -->
        <Grid x:Name="FindDialogOverlay" Grid.RowSpan="5" Visibility="Collapsed" Background="Transparent">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Drop shadow -->
                <Border Margin="4,4,0,0" Background="#FF000055" CornerRadius="0"/>
                <!-- Dialog box -->
                <Border Background="#FF0000AA" BorderBrush="#FF00AAAA" BorderThickness="2"
                        Margin="0,0,4,4" CornerRadius="0" Padding="12">
                    <StackPanel Spacing="10" MinWidth="380">
                        <TextBlock Text="╔═══ Find ═══╗" FontFamily="Consolas" FontSize="14"
                                   Foreground="#FF00AAAA" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Search for:" FontFamily="Consolas" FontSize="13"
                                       Foreground="#FFFFFF55" Width="85" VerticalAlignment="Center"/>
                            <TextBox x:Name="DlgFindSearchBox" Width="250"
                                     FontFamily="Consolas" FontSize="13"
                                     Background="#FF000055" Foreground="#FFFFFFFF"
                                     BorderBrush="#FF00AAAA" BorderThickness="1"
                                     CornerRadius="0" Padding="4,2"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Replace :" FontFamily="Consolas" FontSize="13"
                                       Foreground="#FFFFFF55" Width="85" VerticalAlignment="Center"/>
                            <TextBox x:Name="DlgFindReplaceBox" Width="250"
                                     FontFamily="Consolas" FontSize="13"
                                     Background="#FF000055" Foreground="#FFFFFFFF"
                                     BorderBrush="#FF00AAAA" BorderThickness="1"
                                     CornerRadius="0" Padding="4,2"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <CheckBox x:Name="DlgFindCaseCheck" Foreground="#FFFFFFFF"
                                      FontFamily="Consolas" FontSize="12">
                                <TextBlock Text="Case sensitive" FontFamily="Consolas" FontSize="12"
                                           Foreground="#FFFFFFFF"/>
                            </CheckBox>
                            <CheckBox x:Name="DlgFindWholeWordCheck" Foreground="#FFFFFFFF"
                                      FontFamily="Consolas" FontSize="12">
                                <TextBlock Text="Whole words" FontFamily="Consolas" FontSize="12"
                                           Foreground="#FFFFFFFF"/>
                            </CheckBox>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <Button Content="  OK  " Style="{StaticResource DosDialogButtonStyle}" Click="DlgFind_OK"/>
                            <Button Content="Replace All" Style="{StaticResource DosDialogButtonStyle}" Click="DlgFind_ReplaceAll"/>
                            <Button Content="Cancel" Style="{StaticResource DosDialogButtonStyle}" Click="DlgFind_Cancel"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- GO TO LINE DIALOG -->
        <Grid x:Name="GoToLineDialogOverlay" Grid.RowSpan="5" Visibility="Collapsed" Background="Transparent">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Margin="4,4,0,0" Background="#FF000055" CornerRadius="0"/>
                <Border Background="#FF0000AA" BorderBrush="#FF00AAAA" BorderThickness="2"
                        Margin="0,0,4,4" CornerRadius="0" Padding="12">
                    <StackPanel Spacing="10" MinWidth="300">
                        <TextBlock Text="╔═ Go to Line Number ═╗" FontFamily="Consolas" FontSize="14"
                                   Foreground="#FF00AAAA" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Line #:" FontFamily="Consolas" FontSize="13"
                                       Foreground="#FFFFFF55" VerticalAlignment="Center"/>
                            <TextBox x:Name="DlgGoToLineBox" Width="100"
                                     FontFamily="Consolas" FontSize="13"
                                     Background="#FF000055" Foreground="#FFFFFFFF"
                                     BorderBrush="#FF00AAAA" BorderThickness="1"
                                     CornerRadius="0" Padding="4,2" InputScope="Number"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <Button Content="  OK  " Style="{StaticResource DosDialogButtonStyle}" Click="DlgGoToLine_OK"/>
                            <Button Content="Cancel" Style="{StaticResource DosDialogButtonStyle}" Click="DlgGoToLine_Cancel"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- COMPILER OPTIONS DIALOG -->
        <Grid x:Name="CompilerDialogOverlay" Grid.RowSpan="5" Visibility="Collapsed" Background="Transparent">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Margin="4,4,0,0" Background="#FF000055" CornerRadius="0"/>
                <Border Background="#FF0000AA" BorderBrush="#FF00AAAA" BorderThickness="2"
                        Margin="0,0,4,4" CornerRadius="0" Padding="12">
                    <StackPanel Spacing="8" MinWidth="420">
                        <TextBlock Text="╔══ Compiler Options ══╗" FontFamily="Consolas" FontSize="14"
                                   Foreground="#FF00AAAA" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <StackPanel Spacing="3">
                            <TextBlock Text="Compiler path:" FontFamily="Consolas" FontSize="12" Foreground="#FFFFFF55"/>
                            <TextBox x:Name="DlgCompilerPath" FontFamily="Consolas" FontSize="12"
                                     Background="#FF000055" Foreground="#FFFFFFFF"
                                     BorderBrush="#FF00AAAA" BorderThickness="1" CornerRadius="0"
                                     PlaceholderText="auto-detect"/>
                        </StackPanel>
                        <StackPanel Spacing="3">
                            <TextBlock Text="Include dirs (;-separated):" FontFamily="Consolas" FontSize="12" Foreground="#FFFFFF55"/>
                            <TextBox x:Name="DlgIncludeDirs" FontFamily="Consolas" FontSize="12"
                                     Background="#FF000055" Foreground="#FFFFFFFF"
                                     BorderBrush="#FF00AAAA" BorderThickness="1" CornerRadius="0"/>
                        </StackPanel>
                        <StackPanel Spacing="3">
                            <TextBlock Text="Library dirs (;-separated):" FontFamily="Consolas" FontSize="12" Foreground="#FFFFFF55"/>
                            <TextBox x:Name="DlgLibDirs" FontFamily="Consolas" FontSize="12"
                                     Background="#FF000055" Foreground="#FFFFFFFF"
                                     BorderBrush="#FF00AAAA" BorderThickness="1" CornerRadius="0"/>
                        </StackPanel>
                        <StackPanel Spacing="3">
                            <TextBlock Text="Output directory:" FontFamily="Consolas" FontSize="12" Foreground="#FFFFFF55"/>
                            <TextBox x:Name="DlgOutputDir" FontFamily="Consolas" FontSize="12"
                                     Background="#FF000055" Foreground="#FFFFFFFF"
                                     BorderBrush="#FF00AAAA" BorderThickness="1" CornerRadius="0"
                                     PlaceholderText="same as source"/>
                        </StackPanel>
                        <StackPanel Spacing="3">
                            <TextBlock Text="Additional flags:" FontFamily="Consolas" FontSize="12" Foreground="#FFFFFF55"/>
                            <TextBox x:Name="DlgFlags" FontFamily="Consolas" FontSize="12"
                                     Background="#FF000055" Foreground="#FFFFFFFF"
                                     BorderBrush="#FF00AAAA" BorderThickness="1" CornerRadius="0"
                                     PlaceholderText="-Wall -O2"/>
                        </StackPanel>
