<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="C.Compiler.Controls.EditorControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <!-- Outer DOS-style double border -->
        <Border BorderBrush="#FF00AAAA" BorderThickness="2" Background="#FF0000AA" CornerRadius="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Title bar row (like TC window title bar) -->
                <Grid Grid.Row="0" Background="#FF00AAAA" Height="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Close button [■] -->
                    <Button Grid.Column="0" Content="[■]"
                            FontFamily="Consolas" FontSize="12"
                            Foreground="#FF000000" Background="Transparent"
                            BorderThickness="0" Padding="4,0"
                            VerticalAlignment="Center"
                            CornerRadius="0"
                            Click="CloseButton_Click"/>

                    <!-- Centered filename -->
                    <TextBlock Grid.Column="1" x:Name="TitleText"
                               Text="NONAME.C"
                               FontFamily="Consolas" FontSize="13"
                               Foreground="#FF000000" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <!-- Zoom button [↕] and window number -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBlock x:Name="WindowNumberText" Text="1"
                                   FontFamily="Consolas" FontSize="12"
                                   Foreground="#FF000000"
                                   VerticalAlignment="Center" Margin="4,0"/>
                        <Button Content="[↕]"
                                FontFamily="Consolas" FontSize="12"
                                Foreground="#FF000000" Background="Transparent"
                                BorderThickness="0" Padding="4,0"
                                VerticalAlignment="Center"
                                CornerRadius="0"
                                Click="ZoomButton_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Editor area with line numbers -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Line numbers gutter -->
                    <ScrollViewer x:Name="LineNumberScroller"
                                  Grid.Column="0"
                                  VerticalScrollMode="Disabled"
                                  HorizontalScrollMode="Disabled"
                                  VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Hidden"
                                  Background="#FF000088" MinWidth="44">
                        <TextBlock x:Name="LineNumbers"
                                   FontFamily="Consolas" FontSize="14"
                                   Foreground="#FF00AAAA"
                                   Padding="4,4,8,4"
                                   TextAlignment="Right"/>
                    </ScrollViewer>

                    <!-- Separator line -->
                    <Border Grid.Column="0" HorizontalAlignment="Right"
                            Width="1" Background="#FF00AAAA"/>

                    <!-- Code editor -->
                    <RichEditBox x:Name="CodeEditor"
                                 Grid.Column="1"
                                 FontFamily="Consolas" FontSize="14"
                                 Background="#FF0000AA"
                                 Foreground="#FFFFFF00"
                                 BorderThickness="0"
                                 CornerRadius="0"
                                 Padding="4"
                                 AcceptsReturn="True"
                                 IsSpellCheckEnabled="False"
                                 SelectionHighlightColor="#FF005555"
                                 TextWrapping="NoWrap"
                                 VerticalAlignment="Stretch"
                                 HorizontalAlignment="Stretch"
                                 TextChanged="CodeEditor_TextChanged"
                                 SelectionChanged="CodeEditor_SelectionChanged"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
