<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="C.Compiler.Dialogs.FindReplaceDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Find"
    PrimaryButtonText="Find"
    SecondaryButtonText="Replace"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    Background="#FF0000AA"
    Foreground="#FFFFFFFF"
    BorderBrush="#FF00AAAA"
    BorderThickness="2"
    CornerRadius="0">

    <StackPanel Spacing="12" MinWidth="350">
        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Search for:" VerticalAlignment="Center" Width="80"
                       Foreground="#FFFFFF00" FontFamily="Consolas" FontSize="14"/>
            <TextBox x:ConnectionId='5' x:Name="SearchBox" Width="240"
                     FontFamily="Consolas" FontSize="14"
                     Background="#FF000055" Foreground="#FFFFFFFF"
                     BorderBrush="#FF00AAAA"
                     CornerRadius="0"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Replace:" VerticalAlignment="Center" Width="80"
                       Foreground="#FFFFFF00" FontFamily="Consolas" FontSize="14"/>
            <TextBox x:ConnectionId='4' x:Name="ReplaceBox" Width="240"
                     FontFamily="Consolas" FontSize="14"
                     Background="#FF000055" Foreground="#FFFFFFFF"
                     BorderBrush="#FF00AAAA"
                     CornerRadius="0"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="16">
            <CheckBox x:ConnectionId='2' x:Name="CaseSensitiveCheck" Content="Case sensitive"
                      Foreground="#FFFFFFFF" FontFamily="Consolas" FontSize="13"/>
            <CheckBox x:ConnectionId='3' x:Name="WholeWordCheck" Content="Whole words only"
                      Foreground="#FFFFFFFF" FontFamily="Consolas" FontSize="13"/>
        </StackPanel>
    </StackPanel>
</ContentDialog>

