<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="C.Compiler.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:C.Compiler"
    xmlns:controls="using:C.Compiler.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Turbo C">

    <Grid x:ConnectionId='2' x:Name="RootGrid" Background="#FF0000AA">
        <Grid.RowDefinitions>
            <RowDefinition Height="24"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2"/>
            <RowDefinition Height="140"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- ROW 0: CUSTOM MENU BAR (no WinUI MenuBar)      -->
        <!-- Gray background, black text, flat buttons       -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid x:ConnectionId='3' Grid.Row="0" x:Name="MenuBarGrid" Background="#FFAAAAAA">
            <StackPanel x:ConnectionId='68' x:Name="MenuBarPanel" Orientation="Horizontal" VerticalAlignment="Stretch">
                <Button x:ConnectionId='69' x:Name="SysMenuBtn"     Content=" ≡ "       Style="{StaticResource DosMenuTitleStyle}"                                                          Tag="0"/>
                <Button x:ConnectionId='70' x:Name="FileMenuBtn"    Content=" File "    Style="{StaticResource DosMenuTitleStyle}"                                                          Tag="1"/>
                <Button x:ConnectionId='71' x:Name="EditMenuBtn"    Content=" Edit "    Style="{StaticResource DosMenuTitleStyle}"                                                          Tag="2"/>
                <Button x:ConnectionId='72' x:Name="SearchMenuBtn"  Content=" Search "  Style="{StaticResource DosMenuTitleStyle}"                                                          Tag="3"/>
                <Button x:ConnectionId='73' x:Name="RunMenuBtn"     Content=" Run "     Style="{StaticResource DosMenuTitleStyle}"                                                          Tag="4"/>
                <Button x:ConnectionId='74' x:Name="CompileMenuBtn" Content=" Compile " Style="{StaticResource DosMenuTitleStyle}"                                                          Tag="5"/>
                <Button x:ConnectionId='75' x:Name="DebugMenuBtn"   Content=" Debug "   Style="{StaticResource DosMenuTitleStyle}"                                                          Tag="6"/>
                <Button x:ConnectionId='76' x:Name="ProjectMenuBtn" Content=" Project " Style="{StaticResource DosMenuTitleStyle}"                                                          Tag="7"/>
                <Button x:ConnectionId='77' x:Name="OptionsMenuBtn" Content=" Options " Style="{StaticResource DosMenuTitleStyle}"                                                          Tag="8"/>
                <Button x:ConnectionId='78' x:Name="WindowMenuBtn"  Content=" Window "  Style="{StaticResource DosMenuTitleStyle}"                                                          Tag="9"/>
                <Button x:ConnectionId='79' x:Name="HelpMenuBtn"    Content=" Help "    Style="{StaticResource DosMenuTitleStyle}"                                                          Tag="10"/>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- ROW 1: EDITOR AREA                              -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="2">
            <controls:EditorControl x:ConnectionId='67' x:Name="ActiveEditor"/>
        </Grid>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- ROW 2: DIVIDER                                  -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#FF00AAAA"/>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- ROW 3: MESSAGE WINDOW                           -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border x:ConnectionId='4' Grid.Row="3" x:Name="MessagePanel"
                BorderBrush="#FF00AAAA" BorderThickness="2"
                Margin="2,0,2,0" Background="#FF000088" CornerRadius="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="22"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Background="#FF00AAAA">
                    <TextBlock Text="═══════════════════ Message ═══════════════════"
                               FontFamily="Consolas" FontSize="12"
                               Foreground="#FF000000" HorizontalAlignment="Center"
                               VerticalAlignment="Center" FontWeight="Bold"/>
                </Grid>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="Transparent">
                    <ItemsControl x:ConnectionId='65' x:Name="MessageList" Padding="4,2">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           FontFamily="Consolas" FontSize="13"
                                           Foreground="#FFFFFFFF" TextWrapping="NoWrap" Padding="0,1"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- ROW 4: STATUS BAR                               -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid Grid.Row="4" Background="#FF00AAAA" Padding="2,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" FontFamily="Consolas" FontSize="12"
                       Foreground="#FF000000" VerticalAlignment="Center">
                <Run Text=" F1" FontWeight="Bold" Foreground="#FFFFFFFF"/><Run Text=" Help "/>
                <Run Text="│"/>
                <Run Text=" F2" FontWeight="Bold" Foreground="#FFFFFFFF"/><Run Text=" Save "/>
                <Run Text="│"/>
                <Run Text=" F3" FontWeight="Bold" Foreground="#FFFFFFFF"/><Run Text=" Open "/>
                <Run Text="│"/>
                <Run Text=" Alt+F9" FontWeight="Bold" Foreground="#FFFFFFFF"/><Run Text=" Compile "/>
                <Run Text="│"/>
                <Run Text=" F9" FontWeight="Bold" Foreground="#FFFFFFFF"/><Run Text=" Make "/>
                <Run Text="│"/>
                <Run Text=" F10" FontWeight="Bold" Foreground="#FFFFFFFF"/><Run Text=" Menu"/>
            </TextBlock>
            <TextBlock x:ConnectionId='64' Grid.Column="1" x:Name="StatusLineCol" Text="1:1"
                       FontFamily="Consolas" FontSize="12"
                       Foreground="#FF000000" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="8,0"/>
        </Grid>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- MENU DROPDOWN POPUPS                            -->
        <!-- Each Popup is positioned absolutely via code    -->
        <!-- ═══════════════════════════════════════════════ -->

        <!-- ≡ System Menu -->
        <Popup x:ConnectionId='5' x:Name="MenuPopup0" IsLightDismissEnabled="True"                          >
            <Grid>
                <Border Margin="2,2,0,0" Background="#FF000055" CornerRadius="0"/>
                <Border Background="#FFAAAAAA" BorderBrush="#FF555555" BorderThickness="1" Margin="0,0,2,2" CornerRadius="0">
                    <StackPanel MinWidth="180">
                        <Button x:ConnectionId='63' Content=" About...               " Style="{StaticResource DosMenuItemStyle}"                    />
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button Content=" Clear Desktop           " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Repaint Desktop         " Style="{StaticResource DosMenuItemStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <!-- File Menu -->
        <Popup x:ConnectionId='6' x:Name="MenuPopup1" IsLightDismissEnabled="True"                          >
            <Grid>
                <Border Margin="2,2,0,0" Background="#FF000055" CornerRadius="0"/>
                <Border Background="#FFAAAAAA" BorderBrush="#FF555555" BorderThickness="1" Margin="0,0,2,2" CornerRadius="0">
                    <StackPanel MinWidth="220">
                        <Button x:ConnectionId='56' Content=" New                     " Style="{StaticResource DosMenuItemStyle}"                      />
                        <Button x:ConnectionId='57' Content=" Open...            F3   " Style="{StaticResource DosMenuItemStyle}"                       />
                        <Button x:ConnectionId='58' Content=" Save              F2   " Style="{StaticResource DosMenuItemStyle}"                       />
                        <Button x:ConnectionId='59' Content=" Save as...              " Style="{StaticResource DosMenuItemStyle}"                         />
                        <Button Content=" Save all                " Style="{StaticResource DosMenuItemStyle}"/>
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button x:ConnectionId='60' Content=" Change dir...           " Style="{StaticResource DosMenuItemStyle}"                        />
                        <Button Content=" Print                   " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button x:ConnectionId='61' Content=" DOS shell               " Style="{StaticResource DosMenuItemStyle}"                       />
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button x:ConnectionId='62' Content=" Quit            Alt+X  " Style="{StaticResource DosMenuItemStyle}"                   />
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <!-- Edit Menu -->
        <Popup x:ConnectionId='7' x:Name="MenuPopup2" IsLightDismissEnabled="True"                          >
            <Grid>
                <Border Margin="2,2,0,0" Background="#FF000055" CornerRadius="0"/>
                <Border Background="#FFAAAAAA" BorderBrush="#FF555555" BorderThickness="1" Margin="0,0,2,2" CornerRadius="0">
                    <StackPanel MinWidth="250">
                        <Button x:ConnectionId='51' Content=" Undo          Ctrl+Z    " Style="{StaticResource DosMenuItemStyle}"                       />
                        <Button x:ConnectionId='52' Content=" Redo          Ctrl+Y    " Style="{StaticResource DosMenuItemStyle}"                       />
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button x:ConnectionId='53' Content=" Cut         Shift+Del   " Style="{StaticResource DosMenuItemStyle}"                      />
                        <Button x:ConnectionId='54' Content=" Copy        Ctrl+Ins    " Style="{StaticResource DosMenuItemStyle}"                       />
                        <Button x:ConnectionId='55' Content=" Paste       Shift+Ins   " Style="{StaticResource DosMenuItemStyle}"                        />
                        <Button Content=" Clear        Ctrl+Del   " Style="{StaticResource DosMenuItemStyle}"/>
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button Content=" Copy example            " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Show clipboard          " Style="{StaticResource DosMenuItemStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <!-- Search Menu -->
        <Popup x:ConnectionId='8' x:Name="MenuPopup3" IsLightDismissEnabled="True"                          >
            <Grid>
                <Border Margin="2,2,0,0" Background="#FF000055" CornerRadius="0"/>
                <Border Background="#FFAAAAAA" BorderBrush="#FF555555" BorderThickness="1" Margin="0,0,2,2" CornerRadius="0">
                    <StackPanel MinWidth="260">
                        <Button x:ConnectionId='46' Content=" Find...                  " Style="{StaticResource DosMenuItemStyle}"                         />
                        <Button x:ConnectionId='47' Content=" Replace...               " Style="{StaticResource DosMenuItemStyle}"                            />
                        <Button x:ConnectionId='48' Content=" Search again             " Style="{StaticResource DosMenuItemStyle}"                          />
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button x:ConnectionId='49' Content=" Go to line number...     " Style="{StaticResource DosMenuItemStyle}"                       />
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button Content=" Find procedure...        " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Find error               " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Previous error    Alt+F7 " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button x:ConnectionId='50' Content=" Next error        Alt+F8 " Style="{StaticResource DosMenuItemStyle}"                        />
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <!-- Run Menu -->
        <Popup x:ConnectionId='9' x:Name="MenuPopup4" IsLightDismissEnabled="True"                          >
            <Grid>
                <Border Margin="2,2,0,0" Background="#FF000055" CornerRadius="0"/>
                <Border Background="#FFAAAAAA" BorderBrush="#FF555555" BorderThickness="1" Margin="0,0,2,2" CornerRadius="0">
                    <StackPanel MinWidth="250">
                        <Button x:ConnectionId='44' Content=" Run            Ctrl+F9  " Style="{StaticResource DosMenuItemStyle}"                         />
                        <Button Content=" Program reset  Ctrl+F2  " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Go to cursor      F4    " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Trace into        F7    " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Step over         F8    " Style="{StaticResource DosMenuItemStyle}"/>
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button Content=" Arguments...             " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button x:ConnectionId='45' Content=" User screen    Alt+F5   " Style="{StaticResource DosMenuItemStyle}"                         />
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <!-- Compile Menu -->
        <Popup x:ConnectionId='10' x:Name="MenuPopup5" IsLightDismissEnabled="True"                          >
            <Grid>
                <Border Margin="2,2,0,0" Background="#FF000055" CornerRadius="0"/>
                <Border Background="#FFAAAAAA" BorderBrush="#FF555555" BorderThickness="1" Margin="0,0,2,2" CornerRadius="0">
                    <StackPanel MinWidth="260">
                        <Button x:ConnectionId='42' Content=" Compile to OBJ  Alt+F9  " Style="{StaticResource DosMenuItemStyle}"                      />
                        <Button x:ConnectionId='43' Content=" Make EXE          F9    " Style="{StaticResource DosMenuItemStyle}"                   />
                        <Button Content=" Link EXE file           " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Build all               " Style="{StaticResource DosMenuItemStyle}"/>
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button Content=" Primary C file...       " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Get info                " Style="{StaticResource DosMenuItemStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <!-- Debug Menu -->
        <Popup x:ConnectionId='11' x:Name="MenuPopup6" IsLightDismissEnabled="True"                          >
            <Grid>
                <Border Margin="2,2,0,0" Background="#FF000055" CornerRadius="0"/>
                <Border Background="#FFAAAAAA" BorderBrush="#FF555555" BorderThickness="1" Margin="0,0,2,2" CornerRadius="0">
                    <StackPanel MinWidth="260">
                        <Button Content=" Evaluate/modify Ctrl+F4 " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Watches                 " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Toggle breakpoint Ctrl+F8" Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Breakpoints...          " Style="{StaticResource DosMenuItemStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <!-- Project Menu -->
        <Popup x:ConnectionId='12' x:Name="MenuPopup7" IsLightDismissEnabled="True"                          >
            <Grid>
                <Border Margin="2,2,0,0" Background="#FF000055" CornerRadius="0"/>
                <Border Background="#FFAAAAAA" BorderBrush="#FF555555" BorderThickness="1" Margin="0,0,2,2" CornerRadius="0">
                    <StackPanel MinWidth="220">
                        <Button Content=" Open project...         " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Close project           " Style="{StaticResource DosMenuItemStyle}"/>
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button Content=" Add item...             " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Delete item             " Style="{StaticResource DosMenuItemStyle}"/>
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button Content=" Local options...        " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Include files...        " Style="{StaticResource DosMenuItemStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <!-- Options Menu -->
        <Popup x:ConnectionId='13' x:Name="MenuPopup8" IsLightDismissEnabled="True"                          >
            <Grid>
                <Border Margin="2,2,0,0" Background="#FF000055" CornerRadius="0"/>
                <Border Background="#FFAAAAAA" BorderBrush="#FF555555" BorderThickness="1" Margin="0,0,2,2" CornerRadius="0">
                    <StackPanel MinWidth="220">
                        <Button x:ConnectionId='41' Content=" Compiler...             " Style="{StaticResource DosMenuItemStyle}"                              />
                        <Button Content=" Linker...               " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Make...                 " Style="{StaticResource DosMenuItemStyle}"/>
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button Content=" Directories...          " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Arguments...            " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Environment             " Style="{StaticResource DosMenuItemStyle}"/>
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button Content=" Save options...         " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Retrieve options...     " Style="{StaticResource DosMenuItemStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <!-- Window Menu -->
        <Popup x:ConnectionId='14' x:Name="MenuPopup9" IsLightDismissEnabled="True"                          >
            <Grid>
                <Border Margin="2,2,0,0" Background="#FF000055" CornerRadius="0"/>
                <Border Background="#FFAAAAAA" BorderBrush="#FF555555" BorderThickness="1" Margin="0,0,2,2" CornerRadius="0">
                    <StackPanel MinWidth="260">
                        <Button Content=" Size/Move    Ctrl+F5    " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Zoom            F5      " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Tile                    " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Cascade                 " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Next              F6    " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Previous       Shift+F6 " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Close          Alt+F3   " Style="{StaticResource DosMenuItemStyle}"/>
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button x:ConnectionId='39' Content=" List all...    Alt+0    " Style="{StaticResource DosMenuItemStyle}"                         />
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button x:ConnectionId='40' Content=" Message                 " Style="{StaticResource DosMenuItemStyle}"                                  />
                        <Button Content=" Output                  " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Watch                   " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" User screen    Alt+F5   " Style="{StaticResource DosMenuItemStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <!-- Help Menu -->
        <Popup x:ConnectionId='15' x:Name="MenuPopup10" IsLightDismissEnabled="True"                          >
            <Grid>
                <Border Margin="2,2,0,0" Background="#FF000055" CornerRadius="0"/>
                <Border Background="#FFAAAAAA" BorderBrush="#FF555555" BorderThickness="1" Margin="0,0,2,2" CornerRadius="0">
                    <StackPanel MinWidth="250">
                        <Button Content=" Contents           F1   " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Index          Shift+F1 " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Topic search   Ctrl+F1  " Style="{StaticResource DosMenuItemStyle}"/>
                        <Button Content=" Previous topic Alt+F1   " Style="{StaticResource DosMenuItemStyle}"/>
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button Content=" Help on help            " Style="{StaticResource DosMenuItemStyle}"/>
                        <Border Height="1" Background="#FF555555" Margin="1,0"/>
                        <Button x:ConnectionId='38' Content=" About...                " Style="{StaticResource DosMenuItemStyle}"                    />
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- DIALOG OVERLAYS — inline panels, no WinUI      -->
        <!-- ContentDialog. Pure DOS-styled.                 -->
        <!-- ═══════════════════════════════════════════════ -->

        <!-- FIND / REPLACE DIALOG -->
        <Grid x:ConnectionId='16' x:Name="FindDialogOverlay" Grid.RowSpan="5" Visibility="Collapsed" Background="Transparent">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Drop shadow -->
                <Border Margin="4,4,0,0" Background="#FF000055" CornerRadius="0"/>
                <!-- Dialog box -->
                <Border Background="#FF0000AA" BorderBrush="#FF00AAAA" BorderThickness="2"
                        Margin="0,0,4,4" CornerRadius="0" Padding="12">
                    <StackPanel Spacing="10" MinWidth="380">
                        <TextBlock Text="╔═══ Find ═══╗" FontFamily="Consolas" FontSize="14"
                                   Foreground="#FF00AAAA" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Search for:" FontFamily="Consolas" FontSize="13"
                                       Foreground="#FFFFFF55" Width="85" VerticalAlignment="Center"/>
                            <TextBox x:ConnectionId='37' x:Name="DlgFindSearchBox" Width="250"
                                     FontFamily="Consolas" FontSize="13"
                                     Background="#FF000055" Foreground="#FFFFFFFF"
                                     BorderBrush="#FF00AAAA" BorderThickness="1"
                                     CornerRadius="0" Padding="4,2"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Replace :" FontFamily="Consolas" FontSize="13"
                                       Foreground="#FFFFFF55" Width="85" VerticalAlignment="Center"/>
                            <TextBox x:ConnectionId='36' x:Name="DlgFindReplaceBox" Width="250"
                                     FontFamily="Consolas" FontSize="13"
                                     Background="#FF000055" Foreground="#FFFFFFFF"
                                     BorderBrush="#FF00AAAA" BorderThickness="1"
                                     CornerRadius="0" Padding="4,2"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <CheckBox x:ConnectionId='34' x:Name="DlgFindCaseCheck" Foreground="#FFFFFFFF"
                                      FontFamily="Consolas" FontSize="12">
                                <TextBlock Text="Case sensitive" FontFamily="Consolas" FontSize="12"
                                           Foreground="#FFFFFFFF"/>
                            </CheckBox>
                            <CheckBox x:ConnectionId='35' x:Name="DlgFindWholeWordCheck" Foreground="#FFFFFFFF"
                                      FontFamily="Consolas" FontSize="12">
                                <TextBlock Text="Whole words" FontFamily="Consolas" FontSize="12"
                                           Foreground="#FFFFFFFF"/>
                            </CheckBox>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <Button x:ConnectionId='31' Content="  OK  " Style="{StaticResource DosDialogButtonStyle}"                   />
                            <Button x:ConnectionId='32' Content="Replace All" Style="{StaticResource DosDialogButtonStyle}"                           />
                            <Button x:ConnectionId='33' Content="Cancel" Style="{StaticResource DosDialogButtonStyle}"                       />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- GO TO LINE DIALOG -->
        <Grid x:ConnectionId='17' x:Name="GoToLineDialogOverlay" Grid.RowSpan="5" Visibility="Collapsed" Background="Transparent">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Margin="4,4,0,0" Background="#FF000055" CornerRadius="0"/>
                <Border Background="#FF0000AA" BorderBrush="#FF00AAAA" BorderThickness="2"
                        Margin="0,0,4,4" CornerRadius="0" Padding="12">
                    <StackPanel Spacing="10" MinWidth="300">
                        <TextBlock Text="╔═ Go to Line Number ═╗" FontFamily="Consolas" FontSize="14"
                                   Foreground="#FF00AAAA" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Line #:" FontFamily="Consolas" FontSize="13"
                                       Foreground="#FFFFFF55" VerticalAlignment="Center"/>
                            <TextBox x:ConnectionId='30' x:Name="DlgGoToLineBox" Width="100"
                                     FontFamily="Consolas" FontSize="13"
                                     Background="#FF000055" Foreground="#FFFFFFFF"
                                     BorderBrush="#FF00AAAA" BorderThickness="1"
                                     CornerRadius="0" Padding="4,2" InputScope="Number"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <Button x:ConnectionId='28' Content="  OK  " Style="{StaticResource DosDialogButtonStyle}"                       />
                            <Button x:ConnectionId='29' Content="Cancel" Style="{StaticResource DosDialogButtonStyle}"                           />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- COMPILER OPTIONS DIALOG -->
        <Grid x:ConnectionId='18' x:Name="CompilerDialogOverlay" Grid.RowSpan="5" Visibility="Collapsed" Background="Transparent">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Margin="4,4,0,0" Background="#FF000055" CornerRadius="0"/>
                <Border Background="#FF0000AA" BorderBrush="#FF00AAAA" BorderThickness="2"
                        Margin="0,0,4,4" CornerRadius="0" Padding="12">
                    <StackPanel Spacing="8" MinWidth="420">
                        <TextBlock Text="╔══ Compiler Options ══╗" FontFamily="Consolas" FontSize="14"
                                   Foreground="#FF00AAAA" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <StackPanel Spacing="3">
                            <TextBlock Text="Compiler path:" FontFamily="Consolas" FontSize="12" Foreground="#FFFFFF55"/>
                            <TextBox x:ConnectionId='27' x:Name="DlgCompilerPath" FontFamily="Consolas" FontSize="12"
                                     Background="#FF000055" Foreground="#FFFFFFFF"
                                     BorderBrush="#FF00AAAA" BorderThickness="1" CornerRadius="0"
                                     PlaceholderText="auto-detect"/>
                        </StackPanel>
                        <StackPanel Spacing="3">
                            <TextBlock Text="Include dirs (;-separated):" FontFamily="Consolas" FontSize="12" Foreground="#FFFFFF55"/>
                            <TextBox x:ConnectionId='26' x:Name="DlgIncludeDirs" FontFamily="Consolas" FontSize="12"
                                     Background="#FF000055" Foreground="#FFFFFFFF"
                                     BorderBrush="#FF00AAAA" BorderThickness="1" CornerRadius="0"/>
                        </StackPanel>
                        <StackPanel Spacing="3">
                            <TextBlock Text="Library dirs (;-separated):" FontFamily="Consolas" FontSize="12" Foreground="#FFFFFF55"/>
                            <TextBox x:ConnectionId='25' x:Name="DlgLibDirs" FontFamily="Consolas" FontSize="12"
                                     Background="#FF000055" Foreground="#FFFFFFFF"
                                     BorderBrush="#FF00AAAA" BorderThickness="1" CornerRadius="0"/>
                        </StackPanel>
                        <StackPanel Spacing="3">
                            <TextBlock Text="Output directory:" FontFamily="Consolas" FontSize="12" Foreground="#FFFFFF55"/>
                            <TextBox x:ConnectionId='24' x:Name="DlgOutputDir" FontFamily="Consolas" FontSize="12"
                                     Background="#FF000055" Foreground="#FFFFFFFF"
                                     BorderBrush="#FF00AAAA" BorderThickness="1" CornerRadius="0"
                                     PlaceholderText="same as source"/>
                        </StackPanel>
