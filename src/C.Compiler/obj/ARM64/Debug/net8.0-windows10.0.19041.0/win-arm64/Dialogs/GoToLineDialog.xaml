<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="C.Compiler.Dialogs.GoToLineDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Go to Line Number"
    PrimaryButtonText="OK"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    Background="#FF0000AA"
    Foreground="#FFFFFFFF"
    BorderBrush="#FF00AAAA"
    BorderThickness="2"
    CornerRadius="0">

    <StackPanel Spacing="12" MinWidth="280">
        <TextBlock Text="Enter new line number:" Foreground="#FFFFFF00"
                   FontFamily="Consolas" FontSize="14"/>
        <TextBox x:ConnectionId='2' x:Name="LineNumberBox" Width="120"
                 FontFamily="Consolas" FontSize="14"
                 Background="#FF000055" Foreground="#FFFFFFFF"
                 BorderBrush="#FF00AAAA"
                 CornerRadius="0"
                 HorizontalAlignment="Left"
                 InputScope="Number"/>
    </StackPanel>
</ContentDialog>

