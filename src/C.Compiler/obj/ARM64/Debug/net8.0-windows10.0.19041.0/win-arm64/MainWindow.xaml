<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="C.Compiler.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:C.Compiler"
    xmlns:controls="using:C.Compiler.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Turbo C">

    <Grid Background="{StaticResource DosEditorBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Menu bar -->
            <RowDefinition Height="*"/>      <!-- Editor area -->
            <RowDefinition Height="Auto"/>   <!-- Message window splitter -->
            <RowDefinition Height="150"/>    <!-- Message window -->
            <RowDefinition Height="Auto"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════ -->
        <!-- MENU BAR — Turbo C 3.0 exact menu layout   -->
        <!-- ═══════════════════════════════════════════ -->
        <Grid Grid.Row="0" Background="{StaticResource DosMenuBarBackground}" Height="28">
            <MenuBar VerticalAlignment="Center">
                <!-- ≡ System menu -->
                <MenuBarItem Title="≡" Style="{StaticResource TurboMenuBarItemStyle}">
                    <MenuFlyoutItem x:ConnectionId='33' Text="About..."                    />
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem Text="Clear Desktop"/>
                    <MenuFlyoutItem Text="Repaint Desktop"/>
                </MenuBarItem>

                <!-- File menu -->
                <MenuBarItem Title="File" Style="{StaticResource TurboMenuBarItemStyle}">
                    <MenuFlyoutItem x:ConnectionId='26' Text="New"                      >
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="N" Modifiers="Control"/>
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:ConnectionId='27' Text="Open...       F3"                       >
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="F3" Modifiers="None"/>
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:ConnectionId='28' Text="Save          F2"                       >
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="F2" Modifiers="None"/>
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:ConnectionId='29' Text="Save As..."                         />
                    <MenuFlyoutItem Text="Save All"/>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem x:ConnectionId='30' Text="Change Dir..."                        />
                    <MenuFlyoutItem Text="Print"/>
                    <MenuFlyoutItem x:ConnectionId='31' Text="DOS Shell"                       />
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem x:ConnectionId='32' Text="Quit       Alt+X"                   >
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="X" Modifiers="Menu"/>
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                </MenuBarItem>

                <!-- Edit menu -->
                <MenuBarItem Title="Edit" Style="{StaticResource TurboMenuBarItemStyle}">
                    <MenuFlyoutItem x:ConnectionId='20' Text="Undo             Ctrl+Z"                       >
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="Z" Modifiers="Control"/>
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:ConnectionId='21' Text="Redo             Ctrl+Y"                       >
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="Y" Modifiers="Control"/>
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem x:ConnectionId='22' Text="Cut              Ctrl+X"                      >
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="X" Modifiers="Control"/>
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:ConnectionId='23' Text="Copy             Ctrl+C"                       >
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="C" Modifiers="Control"/>
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:ConnectionId='24' Text="Paste            Ctrl+V"                        >
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="V" Modifiers="Control"/>
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem Text="Clear            Ctrl+Del"/>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem x:ConnectionId='25' Text="Select All       Ctrl+A"                            >
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="A" Modifiers="Control"/>
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                </MenuBarItem>

                <!-- Search menu -->
                <MenuBarItem Title="Search" Style="{StaticResource TurboMenuBarItemStyle}">
                    <MenuFlyoutItem x:ConnectionId='15' Text="Find...          Ctrl+Q+F"                         >
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="F" Modifiers="Control"/>
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:ConnectionId='16' Text="Replace...       Ctrl+Q+A"                            >
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="H" Modifiers="Control"/>
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:ConnectionId='17' Text="Search Again     Ctrl+L"                          />
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem x:ConnectionId='18' Text="Go to Line...    Ctrl+G"                       >
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="G" Modifiers="Control"/>
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem Text="Previous Error   Alt+F7"/>
                    <MenuFlyoutItem x:ConnectionId='19' Text="Next Error       Alt+F8"                        />
                </MenuBarItem>

                <!-- Run menu -->
                <MenuBarItem Title="Run" Style="{StaticResource TurboMenuBarItemStyle}">
                    <MenuFlyoutItem x:ConnectionId='13' Text="Run             Ctrl+F9"                         >
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="F9" Modifiers="Control"/>
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem Text="Program Reset   Ctrl+F2"/>
                    <MenuFlyoutItem Text="Go to Cursor    F4"/>
                    <MenuFlyoutItem Text="Trace Into      F7"/>
                    <MenuFlyoutItem Text="Step Over       F8"/>
                    <MenuFlyoutItem x:ConnectionId='14' Text="User Screen     Alt+F5"                         >
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="F5" Modifiers="Menu"/>
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                </MenuBarItem>

                <!-- Compile menu -->
                <MenuBarItem Title="Compile" Style="{StaticResource TurboMenuBarItemStyle}">
                    <MenuFlyoutItem x:ConnectionId='11' Text="Compile        Alt+F9"                      >
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="F9" Modifiers="Menu"/>
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:ConnectionId='12' Text="Make           F9"                   >
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="F9" Modifiers="None"/>
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem Text="Link"/>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem Text="Build All"/>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem Text="Information..."/>
                    <MenuFlyoutItem Text="Remove Messages"/>
                </MenuBarItem>

                <!-- Debug menu -->
                <MenuBarItem Title="Debug" Style="{StaticResource TurboMenuBarItemStyle}">
                    <MenuFlyoutItem Text="Inspect..."/>
                    <MenuFlyoutItem Text="Evaluate...    Ctrl+F4"/>
                    <MenuFlyoutItem Text="Call Stack     Ctrl+F3"/>
                    <MenuFlyoutItem Text="Watches"/>
                    <MenuFlyoutItem Text="Toggle Breakpoint  Ctrl+F8"/>
                    <MenuFlyoutItem Text="Breakpoints..."/>
                </MenuBarItem>

                <!-- Project menu -->
                <MenuBarItem Title="Project" Style="{StaticResource TurboMenuBarItemStyle}">
                    <MenuFlyoutItem Text="Open Project..."/>
                    <MenuFlyoutItem Text="Close Project"/>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem Text="Add Item..."/>
                    <MenuFlyoutItem Text="Delete Item"/>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem Text="Local Options..."/>
                    <MenuFlyoutItem Text="Include Files..."/>
                </MenuBarItem>

                <!-- Options menu -->
                <MenuBarItem Title="Options" Style="{StaticResource TurboMenuBarItemStyle}">
                    <MenuFlyoutItem x:ConnectionId='10' Text="Compiler..."                              />
                    <MenuFlyoutItem Text="Linker..."/>
                    <MenuFlyoutItem Text="Make..."/>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem Text="Directories..."/>
                    <MenuFlyoutItem Text="Environment"/>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem Text="Save Options..."/>
                    <MenuFlyoutItem Text="Retrieve Options..."/>
                </MenuBarItem>

                <!-- Window menu -->
                <MenuBarItem Title="Window" Style="{StaticResource TurboMenuBarItemStyle}">
                    <MenuFlyoutItem Text="Size/Move      Ctrl+F5"/>
                    <MenuFlyoutItem Text="Zoom           F5"/>
                    <MenuFlyoutItem Text="Tile"/>
                    <MenuFlyoutItem Text="Cascade"/>
                    <MenuFlyoutItem Text="Next           F6"/>
                    <MenuFlyoutItem Text="Previous       Shift+F6"/>
                    <MenuFlyoutItem Text="Close          Alt+F3"/>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem x:ConnectionId='8' Text="List All...    Alt+0"                         />
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem x:ConnectionId='9' Text="Message"                                  />
                    <MenuFlyoutItem Text="Output"/>
                    <MenuFlyoutItem Text="Watch"/>
                    <MenuFlyoutItem Text="User Screen    Alt+F5"/>
                </MenuBarItem>

                <!-- Help menu -->
                <MenuBarItem Title="Help" Style="{StaticResource TurboMenuBarItemStyle}">
                    <MenuFlyoutItem Text="Contents       F1">
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="F1" Modifiers="None"/>
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem Text="Index          Shift+F1"/>
                    <MenuFlyoutItem Text="Topic Search   Ctrl+F1"/>
                    <MenuFlyoutItem Text="Previous Topic Alt+F1"/>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem x:ConnectionId='7' Text="About..."                    />
                </MenuBarItem>
            </MenuBar>
        </Grid>

        <!-- ═══════════════════════════════════════════ -->
        <!-- EDITOR AREA                                 -->
        <!-- ═══════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="2">
            <controls:EditorControl x:ConnectionId='6' x:Name="ActiveEditor"/>
        </Grid>

        <!-- ═══════════════════════════════════════════ -->
        <!-- MESSAGE WINDOW DIVIDER                      -->
        <!-- ═══════════════════════════════════════════ -->
        <Border Grid.Row="2" Height="2"
                Background="{StaticResource DosBorderBrush}"/>

        <!-- ═══════════════════════════════════════════ -->
        <!-- MESSAGE WINDOW (compiler output)            -->
        <!-- ═══════════════════════════════════════════ -->
        <Border x:ConnectionId='2' Grid.Row="3" x:Name="MessagePanel"
                BorderBrush="{StaticResource DosBorderBrush}"
                BorderThickness="2" Margin="2,0,2,0"
                Background="{StaticResource DosMessageBackground}"
                CornerRadius="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Message window title bar -->
                <Grid Grid.Row="0" Background="{StaticResource DosStatusBarBackground}" Height="22">
                    <TextBlock Text="─── Message ───"
                               FontFamily="{StaticResource DosFont}"
                               FontSize="12"
                               Foreground="#FF000000"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontWeight="Bold"/>
                </Grid>

                <!-- Message content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ListView x:ConnectionId='4' x:Name="MessageList"
                              Background="Transparent"
                              SelectionMode="Single"
                                                                             
                              Padding="4,2">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           FontFamily="Consolas" FontSize="13"
                                           Foreground="{StaticResource DosHighlightText}"
                                           TextWrapping="NoWrap"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════ -->
        <!-- STATUS BAR — F-key shortcuts                -->
        <!-- ═══════════════════════════════════════════ -->
        <Grid Grid.Row="4" Background="{StaticResource DosStatusBarBackground}"
              Height="24" Padding="4,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- F-key shortcuts -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4"
                        VerticalAlignment="Center">
                <TextBlock FontFamily="{StaticResource DosFont}" FontSize="12"
                           Foreground="#FF000000" FontWeight="Bold">
                    <Run Text=" F1" FontWeight="Bold" Foreground="#FFFFFFFF"/><Run Text=" Help"/>
                    <Run Text=" │"/>
                    <Run Text=" F2" FontWeight="Bold" Foreground="#FFFFFFFF"/><Run Text=" Save"/>
                    <Run Text=" │"/>
                    <Run Text=" F3" FontWeight="Bold" Foreground="#FFFFFFFF"/><Run Text=" Open"/>
                    <Run Text=" │"/>
                    <Run Text=" Alt+F9" FontWeight="Bold" Foreground="#FFFFFFFF"/><Run Text=" Compile"/>
                    <Run Text=" │"/>
                    <Run Text=" F9" FontWeight="Bold" Foreground="#FFFFFFFF"/><Run Text=" Make"/>
                    <Run Text=" │"/>
                    <Run Text=" F10" FontWeight="Bold" Foreground="#FFFFFFFF"/><Run Text=" Menu"/>
                </TextBlock>
            </StackPanel>

            <!-- Line:Col indicator -->
            <TextBlock x:ConnectionId='3' Grid.Column="1" x:Name="StatusLineCol"
                       Text="1:1"
                       FontFamily="{StaticResource DosFont}" FontSize="12"
                       Foreground="#FF000000" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="8,0"/>
        </Grid>
    </Grid>
</Window>

