<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="C.Compiler.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:C.Compiler">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ══════════════════════════════════════════════ -->
            <!-- DOS CGA Color Palette — Turbo C 3.0           -->
            <!-- ══════════════════════════════════════════════ -->

            <!-- Background colors -->
            <Color x:Key="DosBlue">#FF0000AA</Color>
            <Color x:Key="DosDarkBlue">#FF000088</Color>
            <Color x:Key="DosBlack">#FF000000</Color>

            <!-- Menu / status bar backgrounds -->
            <Color x:Key="DosLightGray">#FFAAAAAA</Color>
            <Color x:Key="DosCyan">#FF00AAAA</Color>
            <Color x:Key="DosDarkCyan">#FF008888</Color>

            <!-- Text colors -->
            <Color x:Key="DosWhite">#FFFFFFFF</Color>
            <Color x:Key="DosYellow">#FFFFFF55</Color>
            <Color x:Key="DosLightCyan">#FF55FFFF</Color>
            <Color x:Key="DosRed">#FFFF5555</Color>
            <Color x:Key="DosGreen">#FF55FF55</Color>
            <Color x:Key="DosDarkRed">#FFAA0000</Color>

            <!-- Brushes -->
            <SolidColorBrush x:Key="DosEditorBackground" Color="#FF0000AA"/>
            <SolidColorBrush x:Key="DosMenuBarBackground" Color="#FFAAAAAA"/>
            <SolidColorBrush x:Key="DosMenuBarForeground" Color="#FF000000"/>
            <SolidColorBrush x:Key="DosStatusBarBackground" Color="#FF00AAAA"/>
            <SolidColorBrush x:Key="DosStatusBarForeground" Color="#FF000000"/>
            <SolidColorBrush x:Key="DosEditorText" Color="#FFFFFF55"/>
            <SolidColorBrush x:Key="DosHighlightText" Color="#FFFFFFFF"/>
            <SolidColorBrush x:Key="DosBorderBrush" Color="#FF00AAAA"/>
            <SolidColorBrush x:Key="DosHotkeyBrush" Color="#FFFF5555"/>
            <SolidColorBrush x:Key="DosMessageBackground" Color="#FF000088"/>
            <SolidColorBrush x:Key="DosMessageForeground" Color="#FFFFFFFF"/>

            <!-- Font -->
            <FontFamily x:Key="DosFont">Consolas</FontFamily>
            <x:Double x:Key="DosFontSize">14</x:Double>
            <x:Double x:Key="DosMenuFontSize">13</x:Double>

            <!-- Override MenuBar styles for DOS look -->
            <Style x:Key="TurboMenuBarItemStyle" TargetType="MenuBarItem">
                <Setter Property="Background" Value="{StaticResource DosMenuBarBackground}"/>
                <Setter Property="Foreground" Value="{StaticResource DosMenuBarForeground}"/>
                <Setter Property="FontFamily" Value="{StaticResource DosFont}"/>
                <Setter Property="FontSize" Value="{StaticResource DosMenuFontSize}"/>
                <Setter Property="Padding" Value="8,2"/>
                <Setter Property="CornerRadius" Value="0"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>

