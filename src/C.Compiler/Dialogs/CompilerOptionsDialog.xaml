<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="C.Compiler.Dialogs.CompilerOptionsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Compiler Options"
    PrimaryButtonText="OK"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    Background="#FF0000AA"
    Foreground="#FFFFFFFF"
    BorderBrush="#FF00AAAA"
    BorderThickness="2"
    CornerRadius="0">

    <StackPanel Spacing="14" MinWidth="400">
        <StackPanel Spacing="4">
            <TextBlock Text="Compiler Path:" Foreground="#FFFFFF00"
                       FontFamily="Consolas" FontSize="13"/>
            <TextBox x:Name="CompilerPathBox"
                     FontFamily="Consolas" FontSize="13"
                     Background="#FF000055" Foreground="#FFFFFFFF"
                     BorderBrush="#FF00AAAA" CornerRadius="0"
                     PlaceholderText="auto-detect"/>
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock Text="Compiler Type:" Foreground="#FFFFFF00"
                       FontFamily="Consolas" FontSize="13"/>
            <ComboBox x:Name="CompilerTypeCombo" Width="200"
                      FontFamily="Consolas" FontSize="13"
                      Background="#FF000055" Foreground="#FFFFFFFF"
                      BorderBrush="#FF00AAAA" CornerRadius="0">
                <ComboBoxItem Content="Auto Detect" Tag="auto"/>
                <ComboBoxItem Content="GCC / MinGW" Tag="gcc"/>
                <ComboBoxItem Content="TCC (Tiny C)" Tag="tcc"/>
                <ComboBoxItem Content="MSVC (cl.exe)" Tag="msvc"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock Text="Include Directories (;-separated):" Foreground="#FFFFFF00"
                       FontFamily="Consolas" FontSize="13"/>
            <TextBox x:Name="IncludeDirsBox"
                     FontFamily="Consolas" FontSize="13"
                     Background="#FF000055" Foreground="#FFFFFFFF"
                     BorderBrush="#FF00AAAA" CornerRadius="0"/>
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock Text="Library Directories (;-separated):" Foreground="#FFFFFF00"
                       FontFamily="Consolas" FontSize="13"/>
            <TextBox x:Name="LibDirsBox"
                     FontFamily="Consolas" FontSize="13"
                     Background="#FF000055" Foreground="#FFFFFFFF"
                     BorderBrush="#FF00AAAA" CornerRadius="0"/>
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock Text="Output Directory:" Foreground="#FFFFFF00"
                       FontFamily="Consolas" FontSize="13"/>
            <TextBox x:Name="OutputDirBox"
                     FontFamily="Consolas" FontSize="13"
                     Background="#FF000055" Foreground="#FFFFFFFF"
                     BorderBrush="#FF00AAAA" CornerRadius="0"
                     PlaceholderText="same as source"/>
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock Text="Additional Flags:" Foreground="#FFFFFF00"
                       FontFamily="Consolas" FontSize="13"/>
            <TextBox x:Name="FlagsBox"
                     FontFamily="Consolas" FontSize="13"
                     Background="#FF000055" Foreground="#FFFFFFFF"
                     BorderBrush="#FF00AAAA" CornerRadius="0"
                     PlaceholderText="-Wall -O2"/>
        </StackPanel>
    </StackPanel>
</ContentDialog>
